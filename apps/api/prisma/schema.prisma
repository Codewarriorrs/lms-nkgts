// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// === ENUMS (PENGATURAN PILIHAN ROLE) ===
enum RoleEnum {
  admin
  guru
  siswa
}

// === MASTER DATA SEKOLAH DUTA ===
model Sekolah {
  id           Int      @id @default(autoincrement())
  nama_sekolah String   @unique @db.VarChar(150)
  alamat       String?  @db.Text
  created_at   DateTime @default(now())
  users        User[]   // Relasi: 1 Sekolah bisa memiliki banyak User
  invitation_tokens InvitationToken[]
}

// === DATA PENGGUNA (RBAC) ===
model User {
  id            String          @id @default(uuid()) @db.Uuid
  sekolah_id    Int?
  sekolah       Sekolah?        @relation(fields: [sekolah_id], references: [id], onDelete: SetNull)
  nama          String          @db.VarChar(150)
  email         String          @unique @db.VarChar(100)
  password_hash String          @db.VarChar(255)
  role          RoleEnum
  nis           String?         @db.VarChar(50) // Ditambahkan sesuai requirement admin invitation

  // === FIELD BARU KELAS SISWA ===
  kelas         String?         @db.VarChar(20)  // Contoh: "Kelas 10", "Kelas 11"
  no_hp         String?         @db.VarChar(20)
  tanggal_lahir DateTime?       @db.Date
  tahun_pendaftaran Int?
  foto_profil   String?         @db.Text
  tempat_lahir  String?         @db.VarChar(100)

  created_at    DateTime        @default(now())
  updated_at    DateTime        @updatedAt

  // Relasi Progres & Nilai Latihan (Dari ERD)
  progres_teori ProgresTeori[]
  nilai_latihan NilaiLatihan[]

  // Relasi Baru ke Modul Praktek
  submisi_praktek SubmisiPraktek[]

  @@map("users") // Mengubah nama tabel di database menjadi huruf kecil 'users'
}

// === TOKENS UNDANGAN AKTIVASI ===
model InvitationToken {
  id         Int      @id @default(autoincrement())
  email      String   @db.VarChar(100)
  token      String   @unique @db.VarChar(255)
  role       RoleEnum
  sekolah_id Int
  sekolah    Sekolah  @relation(fields: [sekolah_id], references: [id], onDelete: Cascade)
  nama       String   @db.VarChar(150)
  nis        String?  @db.VarChar(50)
  is_used    Boolean  @default(false)
  expires_at DateTime
  created_at DateTime @default(now())

  @@map("invitation_tokens")
}

// === SETTINGS GLOBAL ===
model Settings {
  id         Int      @id @default(autoincrement())
  key        String   @unique @db.VarChar(100)
  value      String   @db.Text
  updated_at DateTime @updatedAt

  @@map("settings")
}

// === ENUMS PROGRES ===
enum ProgresEnum {
  belum_dimulai
  sedang_dibaca
  selesai
}

// === TOPIK PELATIHAN ===
model TopikPelatihan {
  id          Int          @id @default(autoincrement())
  nama_topik  String       @db.VarChar(150)
  deskripsi   String?      @db.Text
  created_at  DateTime     @default(now())
  modul_teori ModulTeori[]

  @@map("topik_pelatihan")
}

// === MODUL TEORI ===
model ModulTeori {
  id             Int             @id @default(autoincrement())
  topik_id       Int
  topik          TopikPelatihan  @relation(fields: [topik_id], references: [id], onDelete: Cascade)
  judul          String          @db.VarChar(255)
  slug           String          @unique @db.VarChar(100)
  deskripsi      String?         @db.Text
  file_pdf_url   String?         @db.VarChar(255)
  urutan         Int
  created_at     DateTime        @default(now())

  // Relasi
  progres_teori  ProgresTeori[]
  nilai_latihan  NilaiLatihan[]
  soal_latihan   SoalLatihan[]

  @@map("modul_teori")
}

// === PROGRES TEORI ===
model ProgresTeori {
  id             Int          @id @default(autoincrement())
  siswa_id       String       @db.Uuid
  siswa          User         @relation(fields: [siswa_id], references: [id], onDelete: Cascade)
  modul_teori_id Int
  modul_teori    ModulTeori   @relation(fields: [modul_teori_id], references: [id], onDelete: Cascade)
  status         ProgresEnum  @default(belum_dimulai)
  persentase     Int          @default(0) // Ditambahkan agar melacak % scroll riil
  updated_at     DateTime     @updatedAt

  @@unique([siswa_id, modul_teori_id]) // Satu siswa memiliki satu status progres per modul
  @@map("progres_teori")
}

// === NILAI LATIHAN ===
model NilaiLatihan {
  id             Int        @id @default(autoincrement())
  siswa_id       String     @db.Uuid
  siswa          User       @relation(fields: [siswa_id], references: [id], onDelete: Cascade)
  modul_teori_id Int
  modul_teori    ModulTeori @relation(fields: [modul_teori_id], references: [id], onDelete: Cascade)
  skor           Int
  disubmit_at    DateTime   @default(now())

  @@map("nilai_latihan")
}

// === SOAL LATIHAN ===
model SoalLatihan {
  id             Int        @id @default(autoincrement())
  modul_teori_id Int
  modul_teori    ModulTeori @relation(fields: [modul_teori_id], references: [id], onDelete: Cascade)
  pertanyaan     String     @db.Text
  pilihan_a      String     @db.Text
  pilihan_b      String     @db.Text
  pilihan_c      String     @db.Text
  pilihan_d      String     @db.Text
  jawaban_benar  Int        // Menyimpan index jawaban benar (0, 1, 2, atau 3)
  created_at     DateTime   @default(now())

  @@map("soal_latihan")
}

// === TOPIK TUGAS PRAKTEK (5 TOPIK UTAMA) ===
model TugasPraktek {
  id             Int              @id @default(autoincrement())
  judul          String           @db.VarChar(255)
  deskripsi      String           @db.Text
  urutan         Int              @default(1)
  created_at     DateTime         @default(now())
  submisi        SubmisiPraktek[]

  @@map("tugas_praktek")
}

// === DATA PENGUMPULAN TUGAS SISWA ===
model SubmisiPraktek {
  id               String       @id @default(uuid()) @db.Uuid
  tugas_praktek_id Int
  tugas_praktek    TugasPraktek @relation(fields: [tugas_praktek_id], references: [id], onDelete: Cascade)
  siswa_id         String       @db.Uuid
  siswa            User         @relation(fields: [siswa_id], references: [id], onDelete: Cascade)
  
  // Data dinamis dari input form Isya
  tanggal          String       @db.VarChar(10) // Format: YYYY-MM-DD
  area_pengisian   String       @db.Text        // Input teks area observasi
  keterangan       String?      @db.Text        // Catatan singkat / link bukti
  
  // Data evaluasi penilaian guru
  nilai            Int?
  catatan_guru     String?      @db.Text
  submitted_at     DateTime     @default(now())
  updated_at       DateTime     @updatedAt

  @@unique([siswa_id, tugas_praktek_id]) // Memastikan 1 siswa hanya bisa submit 1 kali per topik
  @@map("submisi_praktek")
}