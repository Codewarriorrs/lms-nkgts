datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  SISWA
  GURU
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  school    String
  avatar    String
  role      Role     @default(SISWA)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}
